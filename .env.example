# =============================================================================
# LLM Provider API Keys (add the ones you want to use)
# =============================================================================

# LM Studio (recommended local learning mode)
# You provided: http://127.0.0.1:1234
LMSTUDIO_BASE_URL=http://127.0.0.1:1234
LMSTUDIO_MODEL=local-model
# Optional explicit override (defaults to openai:${LMSTUDIO_MODEL}):
# ANALYST_PRIMARY_MODEL=openai:local-model

# OpenAI-compatible variables used by many SDKs/tools.
# For LM Studio, a real API key is not required; keep this dummy value.
OPENAI_BASE_URL=http://127.0.0.1:1234/v1
OPENAI_API_KEY=lm-studio

# Anthropic (Claude) - optional (only needed if you want Anthropic models later)
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# Ollama (local — no key needed, just run: ollama serve)
# OLLAMA_BASE_URL=http://localhost:11434/v1

# =============================================================================
# Observability (optional)
# =============================================================================

# Logfire (PydanticAI native tracing)
# LOGFIRE_TOKEN=your-logfire-token

# Langfuse (open-source eval & tracing)
# LANGFUSE_PUBLIC_KEY=your-public-key
# LANGFUSE_SECRET_KEY=your-secret-key
# LANGFUSE_HOST=https://cloud.langfuse.com

# =============================================================================
# E2B (optional — cloud sandbox)
# =============================================================================
# E2B_API_KEY=your-e2b-key

# =============================================================================
# Runtime Controls (optional)
# =============================================================================
# ANALYST_EXECUTION_BACKEND=docker
# ANALYST_ALLOW_UNSAFE_SUBPROCESS=0
# ANALYST_DISABLE_GUARDRAILS=0
# ANALYST_RATE_LIMIT_MAX_REQUESTS=30
# ANALYST_RATE_LIMIT_WINDOW_SECONDS=60
# ANALYST_IDEMPOTENCY_TTL_SECONDS=600
